{
  "typeName": "AWS::Config::Connector",
  "description": "Resource Type definition for AWS::Config::Connector",
  "additionalProperties": false,
  "properties": {
    "Arn": {
      "description": "The Amazon Resource Name (ARN) of the connector.",
      "type": "string"
    },
    "Name": {
      "description": "The name of the connector. AWS Config automatically assigns the name when creating the Connector.",
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "ConnectorConfiguration": {
      "description": "The configuration for the connector that specifies the third-party cloud provider connection details.",
      "$ref": "#/definitions/ConnectorConfiguration"
    },
    "CreatedTime": {
      "description": "The time at which the connector was created.",
      "type": "string"
    },
    "Tags": {
      "description": "The tags for the connector.",
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      }
    }
  },
  "definitions": {
    "ConnectorConfiguration": {
      "description": "The configuration for the connector. Specify the third-party cloud provider configuration.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Azure": {
          "description": "The configuration for connecting to Microsoft Azure.",
          "$ref": "#/definitions/AzureConnectorConfiguration"
        }
      }
    },
    "AzureConnectorConfiguration": {
      "description": "Configuration for connecting to Microsoft Azure.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "TenantIdentifier": {
          "description": "The Azure tenant identifier.",
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "ClientIdentifier": {
          "description": "The Azure client (application) identifier.",
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": [
        "TenantIdentifier",
        "ClientIdentifier"
      ]
    },
    "Tag": {
      "description": "A key-value pair to associate with a resource.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Key": {
          "type": "string",
          "description": "The key name of the tag. You can specify a value that is 1 to 128 Unicode characters in length and cannot be prefixed with aws:.",
          "minLength": 1,
          "maxLength": 128
        },
        "Value": {
          "type": "string",
          "description": "The value for the tag. You can specify a value that is 0 to 256 Unicode characters in length and cannot be prefixed with aws:.",
          "minLength": 0,
          "maxLength": 256
        }
      },
      "required": [
        "Key",
        "Value"
      ]
    }
  },
  "required": [
    "ConnectorConfiguration"
  ],
  "primaryIdentifier": [
    "/properties/Arn"
  ],
  "readOnlyProperties": [
    "/properties/Arn",
    "/properties/Name",
    "/properties/CreatedTime"
  ],
  "createOnlyProperties": [
    "/properties/ConnectorConfiguration"
  ],
  "replacementStrategy": "delete_then_create",
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "cloudFormationSystemTags": true,
    "tagProperty": "/properties/Tags",
    "permissions": [
      "config:TagResource",
      "config:UntagResource",
      "config:ListTagsForResource"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "config:PutConnector",
        "config:GetConnector",
        "config:TagResource",
        "config:ListTagsForResource",
        "iam:CreateServiceLinkedRole"
      ]
    },
    "read": {
      "permissions": [
        "config:GetConnector",
        "config:ListTagsForResource"
      ]
    },
    "update": {
      "permissions": [
        "config:GetConnector",
        "config:TagResource",
        "config:UntagResource",
        "config:ListTagsForResource"
      ]
    },
    "delete": {
      "permissions": [
        "config:DeleteConnector"
      ]
    },
    "list": {
      "permissions": [
        "config:ListConnectors"
      ]
    }
  }
}
