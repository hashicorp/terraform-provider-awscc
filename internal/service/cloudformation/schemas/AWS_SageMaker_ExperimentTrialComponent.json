{
  "typeName": "AWS::SageMaker::ExperimentTrialComponent",
  "description": "Resource type definition for AWS SageMaker Experiment Trial Component",
  "properties": {
    "TrialComponentName": {
      "type": "string",
      "description": "The name of the trial component. The name must be unique in your AWS account and is not case-sensitive.",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9](-*[a-zA-Z0-9]){0,119}$"
    },
    "Arn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the trial component.",
      "maxLength": 256,
      "pattern": "^arn:aws[a-z\\-]*:sagemaker:[a-z0-9\\-]*:[0-9]{12}:experiment-trial-component/"
    },
    "DisplayName": {
      "type": "string",
      "description": "The name of the component as displayed. The name doesn't need to be unique. If DisplayName isn't specified, TrialComponentName is displayed.",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9](-*[a-zA-Z0-9]){0,119}$"
    },
    "Status": {
      "type": "object",
      "description": "The status of the trial component.",
      "properties": {
        "PrimaryStatus": {
          "type": "string",
          "description": "The status of the trial component.",
          "enum": [
            "InProgress",
            "Completed",
            "Failed",
            "Stopping",
            "Stopped"
          ]
        },
        "Message": {
          "type": "string",
          "description": "If the component failed, a message describing why.",
          "maxLength": 1024,
          "pattern": ".*"
        }
      },
      "additionalProperties": false
    },
    "StartTime": {
      "type": "string",
      "description": "When the component started.",
      "format": "date-time"
    },
    "EndTime": {
      "type": "string",
      "description": "When the component ended.",
      "format": "date-time"
    },
    "MetadataProperties": {
      "type": "object",
      "description": "Metadata properties of the tracking entity, trial, or trial component.",
      "properties": {
        "CommitId": {
          "type": "string",
          "description": "The commit ID.",
          "maxLength": 1024,
          "pattern": ".*"
        },
        "Repository": {
          "type": "string",
          "description": "The repository.",
          "maxLength": 1024,
          "pattern": ".*"
        },
        "GeneratedBy": {
          "type": "string",
          "description": "The entity this entity was generated by.",
          "maxLength": 1024,
          "pattern": ".*"
        },
        "ProjectId": {
          "type": "string",
          "description": "The project ID.",
          "maxLength": 1024,
          "pattern": ".*"
        }
      },
      "additionalProperties": false
    },
    "Tags": {
      "type": "array",
      "description": "A list of tags to associate with the component.",
      "items": {
        "type": "object",
        "properties": {
          "Key": {
            "type": "string",
            "description": "The tag key.",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$"
          },
          "Value": {
            "type": "string",
            "description": "The tag value.",
            "maxLength": 256,
            "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$"
          }
        },
        "required": [
          "Key",
          "Value"
        ],
        "additionalProperties": false
      },
      "maxItems": 50
    },
    "CreationTime": {
      "type": "string",
      "description": "When the component was created.",
      "format": "date-time"
    },
    "LastModifiedTime": {
      "type": "string",
      "description": "When the component was last modified.",
      "format": "date-time"
    },
    "LineageGroupArn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the lineage group.",
      "maxLength": 256,
      "pattern": "^arn:aws[a-z\\-]*:sagemaker:[a-z0-9\\-]*:[0-9]{12}:lineage-group/"
    }
  },
  "required": [
    "TrialComponentName"
  ],
  "readOnlyProperties": [
    "/properties/Arn",
    "/properties/CreationTime",
    "/properties/LastModifiedTime",
    "/properties/LineageGroupArn"
  ],
  "createOnlyProperties": [
    "/properties/TrialComponentName",
    "/properties/MetadataProperties"
  ],
  "primaryIdentifier": [
    "/properties/Arn"
  ],
  "additionalIdentifiers": [
    [
      "/properties/TrialComponentName"
    ]
  ],
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "cloudFormationSystemTags": true,
    "tagProperty": "/properties/Tags",
    "permissions": [
      "sagemaker:AddTags",
      "sagemaker:DeleteTags",
      "sagemaker:ListTags"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "sagemaker:CreateTrialComponent",
        "sagemaker:DescribeTrialComponent",
        "sagemaker:AddTags"
      ]
    },
    "read": {
      "permissions": [
        "sagemaker:DescribeTrialComponent",
        "sagemaker:ListTags"
      ]
    },
    "update": {
      "permissions": [
        "sagemaker:UpdateTrialComponent",
        "sagemaker:DescribeTrialComponent",
        "sagemaker:AddTags",
        "sagemaker:DeleteTags",
        "sagemaker:ListTags"
      ]
    },
    "delete": {
      "permissions": [
        "sagemaker:DeleteTrialComponent",
        "sagemaker:DescribeTrialComponent"
      ]
    },
    "list": {
      "permissions": [
        "sagemaker:ListTrialComponents"
      ]
    }
  },
  "additionalProperties": false
}
