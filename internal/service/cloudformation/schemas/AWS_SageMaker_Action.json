{
  "typeName": "AWS::SageMaker::Action",
  "description": "Resource type definition for AWS::SageMaker::Action. An action is a lineage tracking entity that represents an action or activity, such as a model deployment or an HPO job.",
  "definitions": {
    "ActionSource": {
      "type": "object",
      "properties": {
        "SourceUri": {
          "type": "string",
          "description": "The URI of the source.",
          "minLength": 1,
          "maxLength": 2048
        },
        "SourceType": {
          "type": "string",
          "description": "The type of the source.",
          "maxLength": 256
        },
        "SourceId": {
          "type": "string",
          "description": "The ID of the source.",
          "maxLength": 256
        }
      },
      "required": [
        "SourceUri"
      ],
      "additionalProperties": false
    },
    "MetadataProperties": {
      "type": "object",
      "properties": {
        "CommitId": {
          "type": "string",
          "description": "The commit ID.",
          "maxLength": 1024
        },
        "Repository": {
          "type": "string",
          "description": "The repository.",
          "maxLength": 1024
        },
        "GeneratedBy": {
          "type": "string",
          "description": "The entity this entity was generated by.",
          "maxLength": 1024
        },
        "ProjectId": {
          "type": "string",
          "description": "The project ID.",
          "maxLength": 1024
        }
      },
      "additionalProperties": false
    },
    "Tag": {
      "type": "object",
      "properties": {
        "Key": {
          "type": "string",
          "description": "The tag key.",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$"
        },
        "Value": {
          "type": "string",
          "description": "The tag value.",
          "maxLength": 256,
          "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$"
        }
      },
      "required": [
        "Key",
        "Value"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "ActionName": {
      "type": "string",
      "description": "The name of the action. Must be unique to your account in an AWS Region.",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9](-*[a-zA-Z0-9]){0,119}$"
    },
    "ActionType": {
      "type": "string",
      "description": "The action type.",
      "maxLength": 256
    },
    "Source": {
      "$ref": "#/definitions/ActionSource",
      "description": "The source type, ID, and URI."
    },
    "Description": {
      "type": "string",
      "description": "The description of the action.",
      "maxLength": 3072
    },
    "Status": {
      "type": "string",
      "description": "The status of the action.",
      "enum": [
        "Unknown",
        "InProgress",
        "Completed",
        "Failed",
        "Stopping",
        "Stopped"
      ]
    },
    "Properties": {
      "type": "object",
      "description": "A list of properties to add to the action.",
      "patternProperties": {
        "": {
          "type": "string",
          "maxLength": 2500
        }
      },
      "additionalProperties": false,
      "maxProperties": 30
    },
    "MetadataProperties": {
      "$ref": "#/definitions/MetadataProperties",
      "description": "Metadata properties of the tracking entity, trial, or trial component."
    },
    "Tags": {
      "type": "array",
      "description": "A list of tags to apply to the action.",
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "maxItems": 50
    },
    "Arn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the action.",
      "maxLength": 256,
      "pattern": "^arn:aws[a-z\\-]*:sagemaker:[a-z0-9\\-]*:[0-9]{12}:action/"
    },
    "CreationTime": {
      "type": "string",
      "format": "date-time",
      "description": "When the action was created."
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "When the action was last modified."
    }
  },
  "required": [
    "ActionName",
    "ActionType",
    "Source"
  ],
  "readOnlyProperties": [
    "/properties/Arn",
    "/properties/CreationTime",
    "/properties/LastModifiedTime"
  ],
  "createOnlyProperties": [
    "/properties/ActionName",
    "/properties/ActionType",
    "/properties/Source",
    "/properties/MetadataProperties"
  ],
  "primaryIdentifier": [
    "/properties/Arn"
  ],
  "additionalIdentifiers": [
    [
      "/properties/ActionName"
    ]
  ],
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "cloudFormationSystemTags": false,
    "tagProperty": "/properties/Tags",
    "permissions": [
      "sagemaker:AddTags",
      "sagemaker:DeleteTags",
      "sagemaker:ListTags"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "sagemaker:CreateAction",
        "sagemaker:DescribeAction",
        "sagemaker:AddTags",
        "sagemaker:ListTags"
      ]
    },
    "read": {
      "permissions": [
        "sagemaker:DescribeAction",
        "sagemaker:ListTags"
      ]
    },
    "update": {
      "permissions": [
        "sagemaker:UpdateAction",
        "sagemaker:DescribeAction",
        "sagemaker:AddTags",
        "sagemaker:DeleteTags",
        "sagemaker:ListTags"
      ]
    },
    "delete": {
      "permissions": [
        "sagemaker:DeleteAction",
        "sagemaker:DescribeAction",
        "sagemaker:ListTags"
      ]
    },
    "list": {
      "permissions": [
        "sagemaker:ListActions"
      ]
    }
  },
  "additionalProperties": false
}
