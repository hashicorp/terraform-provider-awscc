      "permissions": [
        "glue:CreateUserDefinedFunction",
        "glue:GetUserDefinedFunction"
      ]
    },
    "read": {
      "permissions": [
        "glue:GetUserDefinedFunction"
      ]
    },
    "update": {
      "permissions": [
        "glue:UpdateUserDefinedFunction",
        "glue:GetUserDefinedFunction"
      ]
    },
    "delete": {
      "permissions": [
        "glue:DeleteUserDefinedFunction",
        "glue:GetUserDefinedFunction"
      ]
    },
    "list": {
      "handlerSchema": {
        "properties": {
          "DatabaseName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
