{
  "typeName": "AWS::QuickSight::KnowledgeBase",
  "description": "Definition of AWS::QuickSight::KnowledgeBase Resource Type",
  "definitions": {
    "AccessControlConfiguration": {
      "type": "object",
      "properties": {
        "IsACLEnabled": {
          "type": "boolean",
          "default": null
        }
      },
      "additionalProperties": false
    },
    "AudioExtractionConfiguration": {
      "type": "object",
      "properties": {
        "AudioExtractionStatus": {
          "$ref": "#/definitions/AudioExtractionStatus"
        }
      },
      "required": [
        "AudioExtractionStatus"
      ],
      "additionalProperties": false
    },
    "AudioExtractionStatus": {
      "type": "string",
      "enum": [
        "ENABLED",
        "DISABLED"
      ]
    },
    "DataSetStatus": {
      "type": "string",
      "enum": [
        "CREATING",
        "UPDATING",
        "ACTIVE",
        "FAILED",
        "DELETING"
      ]
    },
    "ImageExtractionConfiguration": {
      "type": "object",
      "properties": {
        "ImageExtractionStatus": {
          "$ref": "#/definitions/ImageExtractionStatus"
        }
      },
      "required": [
        "ImageExtractionStatus"
      ],
      "additionalProperties": false
    },
    "ImageExtractionStatus": {
      "type": "string",
      "enum": [
        "ENABLED",
        "DISABLED"
      ]
    },
    "KbTemplateConfiguration": {
      "type": "object",
      "properties": {
        "Template": {}
      },
      "additionalProperties": false
    },
    "KnowledgeBaseConfiguration": {
      "type": "object",
      "properties": {
        "TemplateConfiguration": {
          "$ref": "#/definitions/KbTemplateConfiguration"
        }
      },
      "additionalProperties": false
    },
    "MediaExtractionConfiguration": {
      "type": "object",
      "properties": {
        "ImageExtractionConfiguration": {
          "$ref": "#/definitions/ImageExtractionConfiguration"
        },
        "AudioExtractionConfiguration": {
          "$ref": "#/definitions/AudioExtractionConfiguration"
        },
        "VideoExtractionConfiguration": {
          "$ref": "#/definitions/VideoExtractionConfiguration"
        }
      },
      "additionalProperties": false
    },
    "ResourcePermission": {
      "type": "object",
      "description": "<p>Permission for the resource.</p>",
      "properties": {
        "Principal": {
          "type": "string",
          "maxLength": 256,
          "minLength": 1,
          "description": "<p>The Amazon Resource Name (ARN) of the principal. This can be one of the\n            following:</p>\n         <ul>\n            <li>\n               <p>The ARN of an Amazon Quick user or group associated with a data source or dataset. (This is common.)</p>\n            </li>\n            <li>\n               <p>The ARN of an Amazon Quick user, group, or namespace associated with an analysis, dashboard, template, or theme. (This is common.)</p>\n            </li>\n            <li>\n               <p>The ARN of an Amazon Web Services account root: This is an IAM ARN rather than a QuickSight\n                    ARN. Use this option only to share resources (templates) across Amazon Web Services accounts.\n                    (This is less common.) </p>\n            </li>\n         </ul>"
        },
        "Resource": {
          "type": "string"
        },
        "Actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 30,
          "minItems": 1,
          "description": "<p>The IAM action to grant or revoke permissions on.</p>"
        }
      },
      "required": [
        "Actions",
        "Principal"
      ],
      "additionalProperties": false
    },
    "Tag": {
      "type": "object",
      "description": "<p>The key or keys of the key-value pairs for the resource tag or tags assigned to the\n            resource.</p>",
      "properties": {
        "Key": {
          "type": "string",
          "maxLength": 128,
          "minLength": 1,
          "description": "<p>Tag key.</p>"
        },
        "Value": {
          "type": "string",
          "maxLength": 256,
          "minLength": 1,
          "description": "<p>Tag value.</p>"
        }
      },
      "required": [
        "Key",
        "Value"
      ],
      "additionalProperties": false
    },
    "VideoExtractionConfiguration": {
      "type": "object",
      "properties": {
        "VideoExtractionStatus": {
          "$ref": "#/definitions/VideoExtractionStatus"
        },
        "VideoExtractionType": {
          "$ref": "#/definitions/VideoExtractionType"
        }
      },
      "required": [
        "VideoExtractionStatus"
      ],
      "additionalProperties": false
    },
    "VideoExtractionStatus": {
      "type": "string",
      "enum": [
        "ENABLED",
        "DISABLED"
      ]
    },
    "VideoExtractionType": {
      "type": "string",
      "enum": [
        "AUDIO_TRANSCRIPTION_ONLY",
        "VISUAL_CONTENT_AND_AUDIO_TRANSCRIPTION"
      ]
    }
  },
  "properties": {
    "AccessControlConfiguration": {
      "$ref": "#/definitions/AccessControlConfiguration"
    },
    "AwsAccountId": {
      "type": "string",
      "maxLength": 12,
      "minLength": 12,
      "pattern": "^[0-9]*$"
    },
    "CreatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "DataSourceArn": {
      "type": "string",
      "maxLength": 1284,
      "minLength": 0,
      "pattern": ""
    },
    "Description": {
      "type": "string",
      "maxLength": 1000,
      "pattern": "^\\P{C}*$"
    },
    "DocumentCount": {
      "type": "number",
      "default": null
    },
    "IsEmailNotificationOptedForIngestionFailures": {
      "type": "boolean",
      "default": null
    },
    "KnowledgeBaseArn": {
      "type": "string",
      "maxLength": 1284,
      "minLength": 0,
      "pattern": ""
    },
    "KnowledgeBaseConfiguration": {
      "$ref": "#/definitions/KnowledgeBaseConfiguration"
    },
    "KnowledgeBaseId": {
      "type": "string",
      "maxLength": 1024,
      "minLength": 1,
      "pattern": "^[0-9a-zA-Z-_=.+]+$"
    },
    "KnowledgeBaseSizeBytes": {
      "type": "number",
      "default": null
    },
    "MediaExtractionConfiguration": {
      "$ref": "#/definitions/MediaExtractionConfiguration"
    },
    "Name": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[\\p{L}\\p{N}][\\p{L}\\p{N} _\\-\\.]*$"
    },
    "Permissions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ResourcePermission"
      },
      "maxItems": 64,
      "minItems": 1
    },
    "PrimaryOwnerArn": {
      "type": "string"
    },
    "PrimaryOwnerUsername": {
      "type": "string"
    },
    "Status": {
      "$ref": "#/definitions/DataSetStatus"
    },
    "Tags": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "maxItems": 200,
      "minItems": 1
    },
    "Type": {
      "type": "string"
    },
    "UpdatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "AwsAccountId",
    "KnowledgeBaseId",
    "Name",
    "DataSourceArn",
    "KnowledgeBaseConfiguration"
  ],
  "readOnlyProperties": [
    "/properties/CreatedAt",
    "/properties/DocumentCount",
    "/properties/KnowledgeBaseArn",
    "/properties/KnowledgeBaseSizeBytes",
    "/properties/PrimaryOwnerUsername",
    "/properties/Status",
    "/properties/Type",
    "/properties/UpdatedAt"
  ],
  "createOnlyProperties": [
    "/properties/AwsAccountId",
    "/properties/DataSourceArn",
    "/properties/KnowledgeBaseId",
    "/properties/PrimaryOwnerArn"
  ],
  "primaryIdentifier": [
    "/properties/AwsAccountId",
    "/properties/KnowledgeBaseId"
  ],
  "handlers": {
    "create": {
      "permissions": [
        "quicksight:CreateKnowledgeBase",
        "quicksight:DescribeDataSource",
        "quicksight:DescribeKnowledgeBase",
        "quicksight:DescribeKnowledgeBasePermissions",
        "quicksight:TagResource",
        "quicksight:ListTagsForResource",
        "quicksight:PassDataSource"
      ]
    },
    "read": {
      "permissions": [
        "quicksight:DescribeKnowledgeBase",
        "quicksight:DescribeKnowledgeBasePermissions",
        "quicksight:ListTagsForResource"
      ]
    },
    "update": {
      "permissions": [
        "quicksight:UpdateKnowledgeBase",
        "quicksight:UpdateKnowledgeBasePermissions",
        "quicksight:DescribeKnowledgeBase",
        "quicksight:DescribeKnowledgeBasePermissions",
        "quicksight:TagResource",
        "quicksight:UntagResource",
        "quicksight:ListTagsForResource",
        "quicksight:PassDataSource"
      ]
    },
    "delete": {
      "permissions": [
        "quicksight:DescribeKnowledgeBase",
        "quicksight:DeleteKnowledgeBase"
      ]
    },
    "list": {
      "permissions": [
        "quicksight:ListKnowledgeBases"
      ]
    }
  },
  "additionalProperties": false,
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-quicksight",
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "tagProperty": "/properties/Tags",
    "cloudFormationSystemTags": false,
    "permissions": [
      "quicksight:TagResource",
      "quicksight:UntagResource",
      "quicksight:ListTagsForResource"
    ]
  },
  "additionalIdentifiers": [
    [
      "/properties/KnowledgeBaseArn"
    ]
  ]
}
