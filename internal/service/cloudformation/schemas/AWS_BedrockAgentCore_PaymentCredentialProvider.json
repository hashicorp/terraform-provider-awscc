{
  "typeName": "AWS::BedrockAgentCore::PaymentCredentialProvider",
  "description": "Resource Type definition for AWS::BedrockAgentCore::PaymentCredentialProvider",
  "definitions": {
    "Tag": {
      "type": "object",
      "properties": {
        "Key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$"
        },
        "Value": {
          "type": "string",
          "minLength": 0,
          "maxLength": 256,
          "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$"
        }
      },
      "required": [
        "Key",
        "Value"
      ],
      "additionalProperties": false
    },
    "PaymentProviderConfigurationInput": {
      "type": "object",
      "description": "Provider configuration input containing secrets for creation/update",
      "properties": {
        "CoinbaseCdpConfiguration": {
          "$ref": "#/definitions/CoinbaseCdpConfigurationInput"
        },
        "StripePrivyConfiguration": {
          "$ref": "#/definitions/StripePrivyConfigurationInput"
        }
      },
      "additionalProperties": false
    },
    "CoinbaseCdpConfigurationInput": {
      "type": "object",
      "description": "Coinbase CDP configuration with API credentials",
      "properties": {
        "ApiKeyId": {
          "type": "string",
          "description": "The Coinbase CDP API key ID",
          "minLength": 1,
          "maxLength": 512
        },
        "ApiKeySecret": {
          "type": "string",
          "description": "The Coinbase CDP API key secret",
          "minLength": 1,
          "maxLength": 2048
        },
        "ApiKeySecretSource": {
          "$ref": "#/definitions/SecretSourceType"
        },
        "ApiKeySecretConfig": {
          "$ref": "#/definitions/SecretReference"
        },
        "WalletSecret": {
          "type": "string",
          "description": "The Coinbase CDP wallet secret",
          "minLength": 1,
          "maxLength": 2048
        },
        "WalletSecretSource": {
          "$ref": "#/definitions/SecretSourceType"
        },
        "WalletSecretConfig": {
          "$ref": "#/definitions/SecretReference"
        }
      },
      "required": [
        "ApiKeyId"
      ],
      "additionalProperties": false
    },
    "PaymentProviderConfigurationOutput": {
      "type": "object",
      "description": "Provider configuration output containing secret ARNs (no raw secrets)",
      "properties": {
        "CoinbaseCdpConfiguration": {
          "$ref": "#/definitions/CoinbaseCdpConfigurationOutput"
        },
        "StripePrivyConfiguration": {
          "$ref": "#/definitions/StripePrivyConfigurationOutput"
        }
      },
      "additionalProperties": false
    },
    "CoinbaseCdpConfigurationOutput": {
      "type": "object",
      "description": "Coinbase CDP configuration output with secret ARNs",
      "properties": {
        "ApiKeyId": {
          "type": "string",
          "description": "The Coinbase CDP API key ID",
          "minLength": 1,
          "maxLength": 512
        },
        "ApiKeySecretArn": {
          "$ref": "#/definitions/SecretInfo"
        },
        "ApiKeySecretJsonKey": {
          "type": "string",
          "description": "The JSON key within the secret that contains the API key secret value",
          "minLength": 1,
          "maxLength": 128
        },
        "ApiKeySecretSource": {
          "$ref": "#/definitions/SecretSourceType"
        },
        "WalletSecretArn": {
          "$ref": "#/definitions/SecretInfo"
        },
        "WalletSecretJsonKey": {
          "type": "string",
          "description": "The JSON key within the secret that contains the wallet secret value",
          "minLength": 1,
          "maxLength": 128
        },
        "WalletSecretSource": {
          "$ref": "#/definitions/SecretSourceType"
        }
      },
      "required": [
        "ApiKeyId",
        "ApiKeySecretArn"
      ],
      "additionalProperties": false
    },
    "SecretInfo": {
      "type": "object",
      "description": "Contains information about a secret in AWS Secrets Manager",
      "properties": {
        "SecretArn": {
          "type": "string",
          "description": "The ARN of the secret in AWS Secrets Manager",
          "pattern": "^arn:(aws|aws-us-gov|aws-cn|aws-iso|aws-iso-b|aws-iso-e|aws-iso-f|aws-eusc):secretsmanager:[A-Za-z0-9-]{1,64}:[0-9]{12}:secret:[a-zA-Z0-9-_/+=.@!]+$"
        }
      },
      "required": [
        "SecretArn"
      ],
      "additionalProperties": false
    },
    "SecretReference": {
      "type": "object",
      "description": "A reference to a customer-provided secret stored in AWS Secrets Manager",
      "properties": {
        "SecretId": {
          "type": "string",
          "description": "The ID or ARN of the secret in AWS Secrets Manager",
          "minLength": 1,
          "maxLength": 2048
        },
        "JsonKey": {
          "type": "string",
          "description": "The JSON key within the secret that contains the credential value",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": [
        "SecretId",
        "JsonKey"
      ],
      "additionalProperties": false
    },
    "SecretSourceType": {
      "type": "string",
      "description": "The source of the secret. Use MANAGED for service-managed secrets or EXTERNAL for customer-provided secrets.",
      "enum": [
        "MANAGED",
        "EXTERNAL"
      ]
    },
    "StripePrivyConfigurationInput": {
      "type": "object",
      "description": "Stripe Privy configuration with credentials",
      "properties": {
        "AppId": {
          "type": "string",
          "description": "The app ID provided by Privy",
          "minLength": 1,
          "maxLength": 512
        },
        "AppSecret": {
          "type": "string",
          "description": "The app secret provided by Privy",
          "minLength": 1,
          "maxLength": 2048
        },
        "AppSecretSource": {
          "$ref": "#/definitions/SecretSourceType"
        },
        "AppSecretConfig": {
          "$ref": "#/definitions/SecretReference"
        },
        "AuthorizationPrivateKey": {
          "type": "string",
          "description": "The authorization private key for the Stripe Privy integration",
          "minLength": 1,
          "maxLength": 4096
        },
        "AuthorizationPrivateKeySource": {
          "$ref": "#/definitions/SecretSourceType"
        },
        "AuthorizationPrivateKeyConfig": {
          "$ref": "#/definitions/SecretReference"
        },
        "AuthorizationId": {
          "type": "string",
          "description": "The authorization ID for the Stripe Privy integration",
          "minLength": 1,
          "maxLength": 512
        }
      },
      "required": [
        "AppId",
        "AuthorizationId"
      ],
      "additionalProperties": false
    },
    "StripePrivyConfigurationOutput": {
      "type": "object",
      "description": "Stripe Privy configuration output with secret ARNs",
      "properties": {
        "AppId": {
          "type": "string",
          "description": "The app ID provided by Privy",
          "minLength": 1,
          "maxLength": 512
        },
        "AppSecretArn": {
          "$ref": "#/definitions/SecretInfo"
        },
        "AppSecretJsonKey": {
          "type": "string",
          "description": "The JSON key within the secret that contains the app secret value",
          "minLength": 1,
          "maxLength": 128
        },
        "AppSecretSource": {
          "$ref": "#/definitions/SecretSourceType"
        },
        "AuthorizationPrivateKeyArn": {
          "$ref": "#/definitions/SecretInfo"
        },
        "AuthorizationPrivateKeyJsonKey": {
          "type": "string",
          "description": "The JSON key within the secret that contains the authorization private key value",
          "minLength": 1,
          "maxLength": 128
        },
        "AuthorizationPrivateKeySource": {
          "$ref": "#/definitions/SecretSourceType"
        },
        "AuthorizationId": {
          "type": "string",
          "description": "The authorization ID for the Stripe Privy integration",
          "minLength": 1,
          "maxLength": 512
        }
      },
      "required": [
        "AppId",
        "AppSecretArn",
        "AuthorizationPrivateKeyArn",
        "AuthorizationId"
      ],
      "additionalProperties": false
    },
    "PaymentCredentialProviderVendorType": {
      "type": "string",
      "description": "Supported vendor types for payment providers",
      "enum": [
        "CoinbaseCDP",
        "StripePrivy"
      ]
    }
  },
  "properties": {
    "Name": {
      "type": "string",
      "description": "Unique name for the payment credential provider",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9\\-_]+$"
    },
    "CredentialProviderVendor": {
      "$ref": "#/definitions/PaymentCredentialProviderVendorType"
    },
    "ProviderConfigurationInput": {
      "$ref": "#/definitions/PaymentProviderConfigurationInput"
    },
    "CredentialProviderArn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the payment credential provider",
      "pattern": "^arn:(aws|aws-us-gov|aws-cn|aws-iso|aws-iso-b|aws-iso-e|aws-iso-f|aws-eusc):(acps|bedrock-agentcore):[A-Za-z0-9-]{1,64}:[0-9]{12}:token-vault/[a-zA-Z0-9-.]+/paymentcredentialprovider/[a-zA-Z0-9_.-]+$"
    },
    "ProviderConfigurationOutput": {
      "$ref": "#/definitions/PaymentProviderConfigurationOutput"
    },
    "CreatedTime": {
      "type": "string",
      "format": "date-time",
      "description": "The timestamp when the credential provider was created"
    },
    "LastUpdatedTime": {
      "type": "string",
      "format": "date-time",
      "description": "The timestamp when the credential provider was last updated"
    },
    "Tags": {
      "type": "array",
      "description": "Tags for the payment credential provider",
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "maxItems": 50,
      "insertionOrder": false
    }
  },
  "additionalProperties": false,
  "required": [
    "Name",
    "CredentialProviderVendor"
  ],
  "readOnlyProperties": [
    "/properties/CredentialProviderArn",
    "/properties/ProviderConfigurationOutput",
    "/properties/CreatedTime",
    "/properties/LastUpdatedTime"
  ],
  "writeOnlyProperties": [
    "/properties/ProviderConfigurationInput"
  ],
  "createOnlyProperties": [
    "/properties/Name"
  ],
  "primaryIdentifier": [
    "/properties/CredentialProviderArn"
  ],
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "tagProperty": "/properties/Tags",
    "cloudFormationSystemTags": true,
    "permissions": [
      "bedrock-agentcore:TagResource",
      "bedrock-agentcore:UntagResource",
      "bedrock-agentcore:ListTagsForResource"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "bedrock-agentcore:CreatePaymentCredentialProvider",
        "bedrock-agentcore:GetPaymentCredentialProvider",
        "bedrock-agentcore:CreateTokenVault",
        "bedrock-agentcore:TagResource",
        "secretsmanager:CreateSecret",
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetSecretValue"
      ]
    },
    "read": {
      "permissions": [
        "bedrock-agentcore:GetPaymentCredentialProvider",
        "bedrock-agentcore:ListTagsForResource"
      ]
    },
    "update": {
      "permissions": [
        "bedrock-agentcore:UpdatePaymentCredentialProvider",
        "bedrock-agentcore:GetPaymentCredentialProvider",
        "bedrock-agentcore:TagResource",
        "bedrock-agentcore:UntagResource",
        "bedrock-agentcore:ListTagsForResource",
        "secretsmanager:PutSecretValue",
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetSecretValue"
      ]
    },
    "delete": {
      "permissions": [
        "bedrock-agentcore:DeletePaymentCredentialProvider",
        "bedrock-agentcore:GetPaymentCredentialProvider",
        "secretsmanager:DeleteSecret"
      ]
    },
    "list": {
      "permissions": [
        "bedrock-agentcore:ListPaymentCredentialProviders"
      ]
    }
  }
}
