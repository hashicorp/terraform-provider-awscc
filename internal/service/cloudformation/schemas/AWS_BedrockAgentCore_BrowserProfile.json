        "DELETING",
        "DELETED",
        "SAVING"
      ],
      "description": "Status of browser profile"
    },
    "CreatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the browser profile was created."
    },
    "LastUpdatedAt": {
