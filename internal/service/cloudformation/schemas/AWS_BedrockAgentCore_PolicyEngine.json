{
  "typeName": "AWS::BedrockAgentCore::PolicyEngine",
  "description": "Resource Type definition for AWS::BedrockAgentCore::PolicyEngine",
  "definitions": {
    "PolicyEngineStatus": {
      "type": "string",
      "enum": [
        "CREATING",
        "ACTIVE",
        "UPDATING",
        "DELETING",
        "CREATE_FAILED",
        "UPDATE_FAILED",
        "DELETE_FAILED"
      ]
    },
    "Tag": {
      "type": "object",
      "properties": {
        "Key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "Value": {
          "type": "string",
          "minLength": 0,
          "maxLength": 256
        }
      },
      "required": [
