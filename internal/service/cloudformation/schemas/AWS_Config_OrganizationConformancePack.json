      "type": "array",
      "items": {
        "$ref": "#/definitions/AccountId"
      },
      "minItems": 0,
      "maxItems": 1000
    },
    "OrganizationConformancePackArn": {
      "description": "Amazon Resource Name (ARN) of the organization conformance pack.",
      "type": "string"
    },
    "Tags": {
      "description": "The tags for the organization conformance pack.",
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/Tag"
      }
    }
  },
  "tagging": {
