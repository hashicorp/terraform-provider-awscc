{
  "typeName": "AWS::SageMaker::TrialComponent",
  "description": "Resource type definition for AWS::SageMaker::TrialComponent. A trial component is a stage of a machine learning trial, such as a preprocessing job, training job, or batch transform job.",
  "definitions": {
    "TrialComponentStatus": {
      "type": "object",
      "description": "The status of the trial component.",
      "properties": {
        "PrimaryStatus": {
          "type": "string",
          "description": "The status of the trial component.",
          "enum": [
            "InProgress",
            "Completed",
            "Failed",
            "Stopping",
            "Stopped"
          ]
        },
        "Message": {
          "type": "string",
          "description": "If the component failed, a message describing why.",
          "maxLength": 1024
        }
      },
      "additionalProperties": false
    },
    "TrialComponentArtifact": {
      "type": "object",
      "description": "Represents an input or output artifact of a trial component.",
      "properties": {
        "MediaType": {
          "type": "string",
          "description": "The media type of the artifact.",
          "maxLength": 64,
          "pattern": "^[-\\w]+\\/[-\\w+]+$"
        },
        "Value": {
          "type": "string",
          "description": "The location of the artifact.",
          "maxLength": 2048
        }
      },
      "required": [
        "Value"
      ],
      "additionalProperties": false
    },
    "TrialComponentParameterValue": {
      "type": "object",
      "description": "The value of a hyperparameter. Only one of StringValue or NumberValue can be specified.",
      "properties": {
        "StringValue": {
          "type": "string",
          "description": "The string value of a categorical hyperparameter.",
          "maxLength": 2500
        },
        "NumberValue": {
          "type": "number",
          "description": "The numeric value of a numeric hyperparameter."
        }
      },
      "additionalProperties": false
    },
    "MetadataProperties": {
      "type": "object",
      "description": "Metadata properties of the tracking entity, trial, or trial component.",
      "properties": {
        "CommitId": {
          "type": "string",
          "description": "The commit ID.",
          "maxLength": 1024
        },
        "Repository": {
          "type": "string",
          "description": "The repository.",
          "maxLength": 1024
        },
        "GeneratedBy": {
          "type": "string",
          "description": "The entity this entity was generated by.",
          "maxLength": 1024
        },
        "ProjectId": {
          "type": "string",
          "description": "The project ID.",
          "maxLength": 1024
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "TrialComponentArn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the trial component.",
      "maxLength": 256,
      "pattern": "^arn:aws[a-z\\-]*:sagemaker:[a-z0-9\\-]*:[0-9]{12}:experiment-trial-component/"
    },
    "TrialComponentName": {
      "type": "string",
      "description": "The name of the trial component. Must be unique in your AWS account and is not case-sensitive.",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9](-*[a-zA-Z0-9]){0,119}$"
    },
    "DisplayName": {
      "type": "string",
      "description": "The name of the component as displayed. If DisplayName isn't specified, TrialComponentName is displayed.",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9](-*[a-zA-Z0-9]){0,119}$"
    },
    "Status": {
      "$ref": "#/definitions/TrialComponentStatus"
    },
    "Parameters": {
      "type": "object",
      "description": "The hyperparameters for the component.",
      "patternProperties": {
        "": {
          "$ref": "#/definitions/TrialComponentParameterValue"
        }
      },
      "maxProperties": 300,
      "additionalProperties": false
    },
    "InputArtifacts": {
      "type": "object",
      "description": "The input artifacts for the component.",
      "patternProperties": {
        "": {
          "$ref": "#/definitions/TrialComponentArtifact"
        }
      },
      "maxProperties": 60,
      "additionalProperties": false
    },
    "OutputArtifacts": {
      "type": "object",
      "description": "The output artifacts for the component.",
      "patternProperties": {
        "": {
          "$ref": "#/definitions/TrialComponentArtifact"
        }
      },
      "maxProperties": 60,
      "additionalProperties": false
    },
    "MetadataProperties": {
      "$ref": "#/definitions/MetadataProperties"
    },
    "Tags": {
      "type": "array",
      "description": "A list of tags to associate with the trial component.",
      "items": {
        "type": "object",
        "properties": {
          "Key": {
            "type": "string",
            "description": "The tag key.",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$"
          },
          "Value": {
            "type": "string",
            "description": "The tag value.",
            "minLength": 0,
            "maxLength": 256,
            "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$"
          }
        },
        "required": [
          "Key",
          "Value"
        ],
        "additionalProperties": false
      },
      "maxItems": 50
    },
    "CreationTime": {
      "type": "string",
      "format": "date-time",
      "description": "When the trial component was created."
    },
    "LastModifiedTime": {
      "type": "string",
      "format": "date-time",
      "description": "When the trial component was last modified."
    },
    "LineageGroupArn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the lineage group.",
      "maxLength": 256
    }
  },
  "required": [
    "TrialComponentName"
  ],
  "readOnlyProperties": [
    "/properties/TrialComponentArn",
    "/properties/CreationTime",
    "/properties/LastModifiedTime",
    "/properties/LineageGroupArn"
  ],
  "createOnlyProperties": [
    "/properties/TrialComponentName",
    "/properties/MetadataProperties"
  ],
  "primaryIdentifier": [
    "/properties/TrialComponentArn"
  ],
  "additionalIdentifiers": [
    [
      "/properties/TrialComponentName"
    ]
  ],
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "cloudFormationSystemTags": false,
    "tagProperty": "/properties/Tags",
    "permissions": [
      "sagemaker:AddTags",
      "sagemaker:DeleteTags",
      "sagemaker:ListTags"
    ]
  },
  "additionalProperties": false,
  "handlers": {
    "create": {
      "permissions": [
        "sagemaker:CreateTrialComponent",
        "sagemaker:DescribeTrialComponent",
        "sagemaker:AddTags",
        "sagemaker:ListTags"
      ]
    },
    "read": {
      "permissions": [
        "sagemaker:DescribeTrialComponent",
        "sagemaker:ListTags"
      ]
    },
    "update": {
      "permissions": [
        "sagemaker:UpdateTrialComponent",
        "sagemaker:DescribeTrialComponent",
        "sagemaker:AddTags",
        "sagemaker:DeleteTags",
        "sagemaker:ListTags"
      ]
    },
    "delete": {
      "permissions": [
        "sagemaker:DeleteTrialComponent",
        "sagemaker:DescribeTrialComponent",
        "sagemaker:ListTags"
      ]
    },
    "list": {
      "permissions": [
        "sagemaker:ListTrialComponents"
      ]
    }
  }
}
