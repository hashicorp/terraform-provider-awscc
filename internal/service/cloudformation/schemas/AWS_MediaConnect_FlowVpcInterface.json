{
  "typeName": "AWS::MediaConnect::FlowVpcInterface",
  "description": "Resource schema for AWS::MediaConnect::FlowVpcInterface",
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-mediaconnect.git",
  "definitions": {
    "Tag": {
      "type": "object",
      "properties": {
        "Key": {
          "type": "string"
        },
        "Value": {
          "type": "string"
        }
      },
      "required": [
        "Key",
        "Value"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "FlowArn": {
      "type": "string",
      "pattern": "^arn:(aws[a-zA-Z-]*):mediaconnect:[a-z0-9-]+:[0-9]{12}:flow:[a-zA-Z0-9-]+:[a-zA-Z0-9_-]+$",
      "description": "The Amazon Resource Name (ARN), a unique identifier for any AWS resource, of the flow."
    },
    "Name": {
      "type": "string",
      "description": "Immutable and has to be a unique against other VpcInterfaces in this Flow."
    },
    "RoleArn": {
      "type": "string",
      "pattern": "^arn:(aws[a-zA-Z-]*):iam::[0-9]{12}:role/[a-zA-Z0-9_+=,.@-]+$",
      "description": "Role Arn MediaConnect can assume to create ENIs in customer's account."
    },
    "SecurityGroupIds": {
      "type": "array",
      "description": "Security Group IDs to be used on ENI.",
      "items": {
        "type": "string"
      }
    },
    "SubnetId": {
      "type": "string",
      "description": "Subnet must be in the AZ of the Flow"
    },
    "NetworkInterfaceIds": {
      "type": "array",
      "description": "IDs of the network interfaces created in customer's account by MediaConnect.",
      "items": {
        "type": "string"
      }
    },
    "Tags": {
      "type": "array",
      "description": "Key-value pairs that can be used to tag and organize this VPC network interface.",
      "uniqueItems": true,
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "FlowArn",
    "Name",
    "RoleArn",
    "SubnetId",
    "SecurityGroupIds"
  ],
  "primaryIdentifier": [
    "/properties/FlowArn",
    "/properties/Name"
  ],
  "readOnlyProperties": [
    "/properties/NetworkInterfaceIds"
  ],
  "createOnlyProperties": [
    "/properties/FlowArn",
    "/properties/Name"
  ],
  "handlers": {
    "create": {
      "permissions": [
        "iam:PassRole",
        "mediaconnect:DescribeFlow",
        "mediaconnect:AddFlowVpcInterfaces",
        "mediaconnect:TagResource",
        "mediaconnect:ListTagsForResource"
      ]
    },
    "read": {
      "permissions": [
        "mediaconnect:DescribeFlow",
        "mediaconnect:ListTagsForResource"
      ]
    },
    "update": {
      "permissions": [
        "iam:PassRole",
        "mediaconnect:DescribeFlow",
        "mediaconnect:AddFlowVpcInterfaces",
        "mediaconnect:RemoveFlowVpcInterface",
        "mediaconnect:TagResource",
        "mediaconnect:UntagResource",
        "mediaconnect:ListTagsForResource"
      ]
    },
    "delete": {
      "permissions": [
        "mediaconnect:DescribeFlow",
        "mediaconnect:RemoveFlowVpcInterface"
      ]
    },
    "list": {
      "permissions": [
        "mediaconnect:DescribeFlow"
      ],
      "handlerSchema": {
        "properties": {
          "FlowArn": {
            "$ref": "resource-schema.json#/properties/FlowArn"
          }
        },
        "required": [
          "FlowArn"
        ]
      }
    }
  },
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "cloudFormationSystemTags": true,
    "tagProperty": "/properties/Tags",
    "permissions": [
      "mediaconnect:TagResource",
      "mediaconnect:UntagResource",
      "mediaconnect:ListTagsForResource"
    ]
  }
}
