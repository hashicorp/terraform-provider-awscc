{
  "typeName": "AWS::SecurityHub::Connector",
  "description": "Resource schema for AWS::SecurityHub::Connector",
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-securityhub",
  "definitions": {
    "Tags": {
      "description": "A key-value pair to associate with a resource.",
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "": {
          "type": "string",
          "description": "The value for the tag.",
          "minLength": 0,
          "maxLength": 256
        }
      }
    },
    "ISO8601DateString": {
      "description": "The timestamp formatted in ISO8601",
      "type": "string",
      "pattern": "^(\\d\\d\\d\\d)-([0][1-9]|[1][0-2])-([0][1-9]|[1-2](\\d)|[3][0-1])[T](?:([0-1](\\d)|[2][0-3]):[0-5](\\d):[0-5](\\d)|23:59:60)(?:\\.(\\d)+)?([Z]|[+-](\\d\\d)(:?(\\d\\d))?)$"
    },
    "AzureScopeConfiguration": {
      "type": "object",
      "description": "The scope configuration for an Azure connector",
      "properties": {
        "ScopeType": {
          "description": "The scope type for the Azure connector",
          "type": "string",
          "enum": [
            "TENANT",
            "SUBSCRIPTION"
          ]
        },
        "ScopeValues": {
          "description": "The list of scope values for the Azure connector",
          "insertionOrder": false,
          "uniqueItems": true,
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 0,
          "maxItems": 100
        }
      },
      "required": [
        "ScopeType"
      ],
      "additionalProperties": false
    },
    "AzureProviderConfiguration": {
      "type": "object",
      "description": "The configuration settings for an Azure CSPM provider",
      "properties": {
        "AWSConfigConnectorArn": {
          "description": "The ARN of the AWS Config connector used for the Azure integration",
          "type": "string"
        },
        "ScopeConfiguration": {
          "$ref": "#/definitions/AzureScopeConfiguration"
        },
        "AzureRegions": {
          "description": "The list of Azure regions to include in the connector scope",
          "type": "array",
          "insertionOrder": false,
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 100
        }
      },
      "required": [
        "AWSConfigConnectorArn",
        "ScopeConfiguration",
        "AzureRegions"
      ],
      "additionalProperties": false
    },
    "Provider": {
      "type": "object",
      "description": "The CSPM provider configuration for the connector",
      "properties": {
        "Azure": {
          "$ref": "#/definitions/AzureProviderConfiguration"
        }
      },
      "required": [
        "Azure"
      ],
      "additionalProperties": false
    },
    "ConnectorStatus": {
      "description": "The status of the connector",
      "type": "string"
    },
    "HealthIssueCode": {
      "description": "The code identifying the type of health issue",
      "type": "string"
    },
    "HealthIssue": {
      "description": "A health issue associated with the connector",
      "type": "object",
      "properties": {
        "Code": {
          "description": "The code identifying the type of health issue",
          "$ref": "#/definitions/HealthIssueCode"
        },
        "Message": {
          "description": "The message describing the health issue",
          "type": "string"
        }
      },
      "required": [
        "Code",
        "Message"
      ],
      "additionalProperties": false
    },
    "EnablementStatus": {
      "description": "The enablement status of the connector",
      "type": "string"
    }
  },
  "properties": {
    "Name": {
      "description": "The name of the connector",
      "type": "string"
    },
    "Description": {
      "description": "A description of the connector",
      "type": "string"
    },
    "Provider": {
      "$ref": "#/definitions/Provider"
    },
    "Tags": {
      "$ref": "#/definitions/Tags"
    },
    "ConnectorArn": {
      "description": "The ARN of the connector",
      "type": "string",
      "pattern": "^arn:aws\\S*:securityhub:[a-z0-9-]+:[0-9]{12}:connector/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "ConnectorId": {
      "description": "The ID of the connector",
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "ConnectorStatus": {
      "$ref": "#/definitions/ConnectorStatus"
    },
    "Message": {
      "description": "The message associated with the connector status change",
      "type": "string"
    },
    "LastCheckedAt": {
      "description": "The date and time for lastCheckedAt in UTC and ISO 8601 format.",
      "$ref": "#/definitions/ISO8601DateString"
    },
    "CreatedAt": {
      "description": "The date and time for createdAt in UTC and ISO 8601 format.",
      "$ref": "#/definitions/ISO8601DateString"
    },
    "LastUpdatedAt": {
      "description": "The date and time for lastUpdatedAt in UTC and ISO 8601 format.",
      "$ref": "#/definitions/ISO8601DateString"
    },
    "CreatedBy": {
      "description": "The principal that created the connector",
      "type": "string"
    },
    "EnablementStatus": {
      "description": "The enablement status of the connector",
      "$ref": "#/definitions/EnablementStatus"
    },
    "Issues": {
      "description": "The list of health issues associated with the connector",
      "type": "array",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/HealthIssue"
      }
    }
  },
  "required": [
    "Name",
    "Provider"
  ],
  "createOnlyProperties": [
    "/properties/Name",
    "/properties/Provider/Azure/AWSConfigConnectorArn"
  ],
  "readOnlyProperties": [
    "/properties/ConnectorArn",
    "/properties/ConnectorId",
    "/properties/ConnectorStatus",
    "/properties/Message",
    "/properties/LastCheckedAt",
    "/properties/CreatedAt",
    "/properties/LastUpdatedAt",
    "/properties/CreatedBy",
    "/properties/EnablementStatus",
    "/properties/Issues"
  ],
  "primaryIdentifier": [
    "/properties/ConnectorArn"
  ],
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "cloudFormationSystemTags": true,
    "tagProperty": "/properties/Tags",
    "permissions": [
      "securityhub:ListTagsForResource",
      "securityhub:TagResource",
      "securityhub:UntagResource"
    ]
  },
  "additionalProperties": false,
  "handlers": {
    "create": {
      "permissions": [
        "securityhub:CreateConnector",
        "securityhub:GetConnector",
        "securityhub:TagResource",
        "securityhub:ListTagsForResource"
      ]
    },
    "read": {
      "permissions": [
        "securityhub:GetConnector",
        "securityhub:ListTagsForResource"
      ]
    },
    "update": {
      "permissions": [
        "securityhub:UpdateConnector",
        "securityhub:GetConnector",
        "securityhub:TagResource",
        "securityhub:UntagResource",
        "securityhub:ListTagsForResource"
      ]
    },
    "delete": {
      "permissions": [
        "securityhub:GetConnector",
        "securityhub:DeleteConnector"
      ]
    },
    "list": {
      "permissions": [
        "securityhub:ListConnectors",
        "securityhub:ListTagsForResource"
      ]
    }
  }
}
