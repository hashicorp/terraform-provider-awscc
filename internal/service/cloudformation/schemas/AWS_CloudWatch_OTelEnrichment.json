{
  "typeName": "AWS::CloudWatch::OTelEnrichment",
  "description": "AWS::CloudWatch::OTelEnrichment enables OTel metric enrichment in CloudWatch, allowing CloudWatch vended metrics to be available for PromQL querying enriched with AWS resource tags and metadata.",
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
  "definitions": {
    "Status": {
      "description": "Current status of OTel enrichment (RUNNING or STOPPED).",
      "type": "string",
      "enum": [
        "RUNNING",
        "STOPPED"
      ]
    }
  },
  "tagging": {
    "taggable": false
  },
  "properties": {
    "AccountId": {
      "description": "The AWS account ID. This is the primary identifier for this singleton resource.",
      "type": "string"
    },
    "Status": {
      "$ref": "#/definitions/Status"
    }
  },
  "additionalProperties": false,
  "required": [],
  "readOnlyProperties": [
    "/properties/AccountId",
    "/properties/Status"
  ],
  "primaryIdentifier": [
    "/properties/AccountId"
  ],
  "handlers": {
    "create": {
      "permissions": [
        "cloudwatch:StartOTelEnrichment",
        "cloudwatch:GetOTelEnrichment"
      ]
    },
    "read": {
      "permissions": [
        "cloudwatch:GetOTelEnrichment"
      ]
    },
    "update": {
      "permissions": [
        "cloudwatch:StartOTelEnrichment",
        "cloudwatch:GetOTelEnrichment"
      ]
    },
    "delete": {
      "permissions": [
        "cloudwatch:StopOTelEnrichment",
        "cloudwatch:GetOTelEnrichment"
      ]
    },
    "list": {
      "permissions": [
        "cloudwatch:GetOTelEnrichment"
      ]
    }
  }
}
